def NotasAlunos():
    os.system("clear")
    materias = ["PORTUGUÊS", "MATEMÁTICA", "HISTÓRIA", "GEOGRAFIA", "BIOLOGIA", "FÍSICA", "QUÍMICA", "FILOSOFIA"]
    notas = {}
    for materias in materias:
        #sys.stdout.write("\033[4F]")
        print(f"\n{materias}")
        notas_prova = float(input("Digite a sua nota total de prova: "))
        notas_teste = float(input("Digite a sua nota total de teste: "))
        notas_trabalho = float(input("Digite a sua nota total de trabalho: "))
        os.system("clear")

        notas[materias] = notas_prova, notas_teste, notas_trabalho
NotasAlunos()


