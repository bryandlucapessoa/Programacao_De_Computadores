print(f"""
Bem-vindo ao seu sistema de notas escolar, {nome_aluno}! 
A seguir, digite as suas notas em cada materia disponível.'
""")


def notas_alunos():
    lista_materias = ["PORTUGUÊS", "MATEMÁTICA", "HISTÓRIA", "GEOGRAFIA", 
                      "BIOLOGIA", "FÍSICA", "QUÍMICA", "FILOSOFIA"]
    notas = {}
    limpar = "cls" if os.name == "nt" else "clear"

    for i, materia in enumerate(lista_materias):
        os.system(limpar)
        print(f"Matéria {i+1} de {len(lista_materias)}: {materia}\n")
        notas_prova    = float(input("Digite a sua nota total de prova: "))
        notas_teste    = float(input("Digite a sua nota total de teste: "))
        notas_trabalho = float(input("Digite a sua nota total de trabalho: "))
        
        notas[materia] = {"prova": notas_prova, "teste": notas_teste, "trabalho": notas_trabalho}

    return notas
notas_alunos()


